---
import { links } from '../data/links';
import type { Content } from '../data/types';

interface Props {
  t: Content;
}

const { t } = Astro.props;

const buttons = [
  {
    href: links.email,
    label: t.contact.email,
    external: false,
    icon: 'M4 6h16a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1Zm.4 2 7.6 5.4L19.6 8',
  },
  {
    href: links.whatsapp,
    label: t.contact.whatsapp,
    external: true,
    icon: 'M12 3a9 9 0 0 0-7.8 13.5L3 21l4.7-1.2A9 9 0 1 0 12 3Zm4 12.3c-.2.6-1.2 1.2-1.7 1.2-.4.1-1 .1-1.6-.1a13 13 0 0 1-1.5-.5c-2.6-1.1-4.3-3.7-4.4-3.9-.1-.2-1.1-1.4-1.1-2.7 0-1.3.7-1.9.9-2.2.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.4.5c-.1.1-.3.3-.1.6.2.3.8 1.3 1.7 2.1 1.2 1.1 2.2 1.4 2.5 1.5.3.1.5.1.7-.1l.9-1.1c.2-.3.4-.2.7-.1l2 .9c.3.2.5.3.6.4 0 .2 0 .8-.2 1.4Z',
  },
  {
    href: links.linkedin,
    label: t.contact.linkedin,
    external: true,
    icon: 'M6.5 8.5v11M6.5 5a1 1 0 1 0 0-.01M11 19.5v-6a3 3 0 0 1 6 0v6M11 8.5v2',
  },
];
---

<section id="contato" class="relative scroll-mt-20 overflow-hidden">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute bottom-0 left-1/2 h-100 w-200 -translate-x-1/2 translate-y-1/2 rounded-full bg-volt/10 blur-[130px]"
  >
  </div>

  <div class="relative mx-auto max-w-4xl px-5 py-28 text-center md:py-40">
    <p class="section-label reveal">{t.contact.label}</p>
    <h2 class="mega reveal mt-6" style="--rd:0.08s">
      {t.contact.title}
    </h2>
    <p class="reveal mx-auto mt-6 max-w-xl text-zinc-400" style="--rd:0.15s">{t.contact.subtitle}</p>

    <div class="reveal mt-12 flex flex-wrap items-center justify-center gap-4" style="--rd:0.2s">
      {
        buttons.map((btn, i) => (
          <a
            href={btn.href}
            target={btn.external ? '_blank' : undefined}
            rel={btn.external ? 'noopener noreferrer' : undefined}
            class={i === 0 ? 'btn-volt' : 'btn-ghost'}
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d={btn.icon} />
            </svg>
            {btn.label}
          </a>
        ))
      }
    </div>
  </div>
</section>
