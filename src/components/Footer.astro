---
import type { Content } from '../data/types';

interface Props {
  t: Content;
}

const { t } = Astro.props;
---

<footer class="border-t border-zinc-900">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-2 px-5 py-8 text-sm text-zinc-500 sm:flex-row">
    <p class="font-display text-base tracking-tight text-zinc-300 uppercase">
      lucas<span class="text-volt">.dev</span>
    </p>
    <p>© 2026 Lucas de Moraes Souza</p>
    <p>{t.footer.madeWith}</p>
  </div>
</footer>
