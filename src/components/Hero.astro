---
import { Image } from 'astro:assets';
import cutout from '../assets/lucas-cutout.png';
import { links } from '../data/links';
import type { Content } from '../data/types';

interface Props {
  t: Content;
}

const { t } = Astro.props;

const line1 = 'LUCAS DE';
const line2 = 'MORAES SOUZA';
let letterIndex = 0;
const letters = (line: string) =>
  line.split('').map((ch) => ({ ch: ch === ' ' ? '\u00A0' : ch, delay: 0.15 + letterIndex++ * 0.035 }));
const l1 = letters(line1);
const l2 = letters(line2);
---

<section id="top" class="relative flex h-svh min-h-160 flex-col justify-end overflow-hidden">
  <!-- brilho volt atrás da pessoa -->
  <div
    aria-hidden="true"
    class="absolute bottom-0 left-1/2 h-[60svh] w-[60svh] -translate-x-1/2 translate-y-1/4 rounded-full bg-volt/14 blur-[110px]"
  >
  </div>

  <!-- nome gigante atrás -->
  <div id="hero-name" class="absolute inset-x-0 top-[12svh] z-0 px-3 text-center select-none">
    <h1 class="font-display leading-[0.88] tracking-tight text-zinc-100 uppercase">
      <span class="hero-line text-[clamp(3.2rem,14.5vw,13rem)]">
        {l1.map(({ ch, delay }) => (
          <span class="hero-letter" style={`--d:${delay}s`}>{ch}</span>
        ))}
      </span>
      <span class="hero-line text-volt text-[clamp(2rem,9.2vw,8.2rem)]">
        {l2.map(({ ch, delay }) => (
          <span class="hero-letter" style={`--d:${delay}s`}>{ch}</span>
        ))}
      </span>
    </h1>
  </div>

  <!-- pessoa em recorte -->
  <div id="hero-person" class="pointer-events-none absolute bottom-44 left-1/2 z-10 -translate-x-1/2 sm:bottom-0">
    <Image
      src={cutout}
      alt={t.hero.photoAlt}
      loading="eager"
      fetchpriority="high"
      quality={90}
      class="hero-person h-[52svh] w-auto max-w-none object-contain object-bottom drop-shadow-[0_0_60px_rgba(0,0,0,0.8)] sm:h-[66svh]"
    />
  </div>

  <!-- vinheta para legibilidade do rodapé do hero -->
  <div
    aria-hidden="true"
    class="absolute inset-x-0 bottom-0 z-20 h-72 bg-gradient-to-t from-zinc-950 via-zinc-950/60 to-transparent sm:h-48 sm:via-zinc-950/30"
  >
  </div>

  <!-- infos sobre a imagem -->
  <div class="relative z-30 mx-auto w-full max-w-6xl px-5 pb-10">
    <div class="hero-fade flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-end">
      <div>
        <p class="font-grotesk text-sm font-bold tracking-[0.3em] text-volt uppercase">{t.hero.role}</p>
        <p class="mt-2 text-sm text-zinc-400">{t.hero.tagline}</p>
        <p class="mt-1 font-grotesk text-xs tracking-widest text-zinc-500 uppercase">{t.hero.location}</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="#contato" class="btn-volt">{t.hero.ctaContact}</a>
        <a href={links.linkedin} target="_blank" rel="noopener noreferrer" class="btn-ghost">
          {t.hero.ctaLinkedin}
        </a>
      </div>
    </div>

    <div class="hero-fade mt-8 flex justify-center">
      <a href="#sobre" class="scroll-hint flex flex-col items-center gap-1 text-zinc-500 transition-colors hover:text-volt">
        <span class="font-grotesk text-[10px] tracking-[0.3em] uppercase">{t.hero.scrollHint}</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 5v14m0 0-6-6m6 6 6-6" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
