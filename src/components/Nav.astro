---
import type { Content } from '../data/types';

interface Props {
  t: Content;
  altUrl: string;
  altLabel: string;
}

const { t, altUrl, altLabel } = Astro.props;

const items = [
  { href: '#sobre', label: t.nav.about },
  { href: '#skills', label: t.nav.skills },
  { href: '#experiencia', label: t.nav.experience },
  { href: '#formacao', label: t.nav.education },
  { href: '#contato', label: t.nav.contact },
];
---

<header
  id="site-nav"
  class="fixed inset-x-0 top-0 z-50 border-b border-transparent transition-all duration-300"
>
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5">
    <a href="#top" class="font-display text-lg tracking-tight text-zinc-100 uppercase">
      lucas<span class="text-volt">.dev</span>
    </a>

    <div class="hidden items-center gap-7 md:flex">
      {
        items.map((item) => (
          <a
            href={item.href}
            class="font-grotesk text-xs font-semibold tracking-[0.2em] text-zinc-400 uppercase transition-colors hover:text-volt"
          >
            {item.label}
          </a>
        ))
      }
      <a
        href={altUrl}
        class="rounded-full border border-zinc-700 px-3 py-1 font-grotesk text-xs font-bold text-zinc-300 uppercase transition-colors hover:border-volt hover:text-volt"
      >
        {altLabel}
      </a>
    </div>

    <div class="flex items-center gap-3 md:hidden">
      <a
        href={altUrl}
        class="rounded-full border border-zinc-700 px-3 py-1 font-grotesk text-xs font-bold text-zinc-300 uppercase"
      >
        {altLabel}
      </a>
      <button
        id="menu-btn"
        type="button"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="flex h-9 w-9 items-center justify-center rounded-lg border border-zinc-700 text-zinc-300"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"></path>
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-zinc-800/60 bg-zinc-950/95 px-5 py-4 backdrop-blur-md md:hidden">
    <div class="flex flex-col gap-4">
      {
        items.map((item) => (
          <a
            href={item.href}
            class="font-grotesk text-sm font-semibold tracking-[0.2em] text-zinc-300 uppercase"
            data-menu-link
          >
            {item.label}
          </a>
        ))
      }
    </div>
  </div>
</header>

<script>
  const nav = document.getElementById('site-nav');
  const solid = ['bg-zinc-950/80', 'backdrop-blur-md', 'border-zinc-800/60'];
  const update = () => {
    if (scrollY > 40) nav?.classList.add(...solid);
    else nav?.classList.remove(...solid);
  };
  addEventListener('scroll', update, { passive: true });
  update();

  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(open));
    if (open) nav?.classList.add(...solid);
  });
  document.querySelectorAll('[data-menu-link]').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
